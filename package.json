{
  "name": "pocket-claude",
  "version": "2.0.0",
  "description": "Mobile interface for Claude Code - pipes prompts from phone into Claude Code SDK over Tailscale",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "db:generate": "drizzle-kit generate"
  },
  "keywords": [],
  "author": "Nick",
  "license": "ISC",
  "engines": {
    "node": ">=24"
  },
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
