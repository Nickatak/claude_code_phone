# Shared by both relay server and worker.
# For dev, use .env.development (tracked in git, no secrets).
# For prod, use .env.production (gitignored).
# .env is always loaded as fallback.

# Relay server
PORT=3000
DB_PATH=./data/relay.db

# Worker
AUTH_TOKEN=your-secret-token-here
RELAY_URL=http://100.x.x.x:3000
WORKER_CWD=/home/nick/some-project
